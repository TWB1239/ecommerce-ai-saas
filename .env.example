# ============================================
# AI 电商运营助手 - 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ============================================

# Supabase 项目信息（在 supabase.com 后台获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek API（在 platform.deepseek.com 获取）
# 也可以用其他 OpenAI 兼容的 API（如通义千问、GLM等）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Stripe 支付（在 stripe.com 获取）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# 套餐价格 ID（在 Stripe 后台创建产品后获取）
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_YEARLY=price_yearly_id

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
SITE_NAME=AI电商运营助手
